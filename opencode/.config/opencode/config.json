{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["opencode-gemini-auth@latest", "opencode-qwencode-auth@latest", "@slkiser/opencode-quota"],
    "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask",
        "external_directory": "ask",
        "webfetch": "ask",
        "doom_loop": "ask"
    },
    "default_agent": "orchestrator",
    "instructions": [
        "workflow.md"
    ],
    "experimental": {
        "quotaToast": {
            "enableToast": false,
        },
    },
    "mcp": {
        "docker": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@alisaitteke/docker-mcp"
            ]
        }
    }
}
