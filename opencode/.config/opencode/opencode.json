{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["@simonwjackson/opencode-direnv"],
    "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask",
        "external_directory": "ask",
        "webfetch": "ask",
        "doom_loop": "ask",
        "lsp": "deny"
    },
    "mcp": {
        "docker": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@alisaitteke/docker-mcp"
            ]
        }
    },
    "provider": {
        "opencode-go-secondary": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "OpenCode Go (Secondary)",
            "options": {
                "baseURL": "https://opencode.ai/zen/go/v1/",
            },
            "models": {
                "mimo-v2.5": {
                    "name": "MiMo V2.5"
                },
                "mimo-v2.5-pro": {
                    "name": "MiMo V2.5 Pro"
                },
                "qwen3.7-max": {
                    "name": "Qwen3.7 Max"
                },
                "qwen3.7-plus": {
                    "name": "Qwen3.7 Plus"
                },
            }
        }
    }
}
