{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["opencode-gemini-auth@latest", "opencode-qwencode-auth@latest", "@simonwjackson/opencode-direnv"],
    "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask",
        "external_directory": "ask",
        "webfetch": "ask",
        "doom_loop": "ask",
        "lsp": "deny"
    },
    "mcp": {
        "docker": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@alisaitteke/docker-mcp"
            ]
        }
    }
}
