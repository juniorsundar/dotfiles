{
  "defaultModel": "deepseek-v4-pro",
  "defaultProvider": "opencode-go",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "lastChangelogVersion": "0.76.0",
  "packages": [
    "git:github.com/mrexodia/kilo-pi-provider",
    "git:github.com/juicesharp/rpiv-mono",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@sherif-fanous/pi-atom-one",
    "npm:pi-ollama-cloud-provider"
  ],
  "enabledModels": [
    "llama-cpp/qwen3.6-35b-a3b-local",
    "openai-codex/gpt-5.5",
    "minimax/MiniMax-M2.7",
    "ollama-cloud/deepseek-v4-pro",
    "ollama-cloud/deepseek-v4-flash",
    "ollama-cloud/glm-5.1",
    "ollama-cloud/qwen3.5:397b",
    "opencode-go/glm-5.1",
    "opencode-go/kimi-k2.6",
    "opencode-go/qwen3.6-plus",
    "opencode-go/deepseek-v4-flash",
    "opencode-go/deepseek-v4-pro",
    "openai-codex/gpt-5.4"
  ],
  "theme": "atom-one-dark",
  "enableInstallTelemetry": false,
  "shellCommandPrefix": "export DIRENV_LOG_FORMAT=''; if command -v direnv >/dev/null 2>&1; then eval \"$(direnv export bash 2>/dev/null)\"; fi",
  "doubleEscapeAction": "tree",
  "subagents": {
    "agentOverrides": {
      "delegate": {
        "defaultProgress": true
      },
      "oracle": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "xhigh",
        "defaultProgress": true,
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "high",
        "defaultProgress": true,
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "worker": {
        "model": "ollama-cloud/deepseek-v4-pro",
        "thinking": "high",
        "defaultProgress": true,
        "fallbackModels": [
          "minimax/MiniMax-M2.7"
        ]
      },
      "criteria-auditor": {
        "model": "minimax/MiniMax-M2.7",
        "thinking": "medium",
        "defaultProgress": true,
        "fallbackModels": [
          "ollama-cloud/deepseek-v4-flash"
        ]
      },
      "checkpoint-reviewer": {
        "model": "ollama-cloud/deepseek-v4-flash",
        "thinking": "high",
        "defaultProgress": true,
        "fallbackModels": [
          "opencode-go/deepseek-v4-flash",
          "minimax/MiniMax-M2.7"
        ]
      }
    }
  },
  "images": {
    "blockImages": false
  }
}