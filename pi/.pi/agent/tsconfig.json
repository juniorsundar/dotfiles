{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "typeRoots": ["node_modules/@types", ".direnv/node_modules/@types"],
    "paths": {
      "@earendil-works/*": [".direnv/node_modules/@earendil-works/*"],
      "typebox": [".direnv/node_modules/typebox"]
    }
  },
  "include": ["extensions/confirm-mutating-tools.ts"]
}
