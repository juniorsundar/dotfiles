[{    
    "name": "top",
        "custom/os_button": {
            "format": "пМУ",
            "on-click": "rofi -show drun",
            "tooltip": false
        },
        "sway/workspaces": {
            "disable-scroll": true,
            "format": "{icon}",
        },
        "hyprland/workspaces": {
            "format": "{icon}",
            "on-scroll-up": "hyprctl dispatch workspace e+1",
            "on-scroll-down": "hyprctl dispatch workspace e-1",
            "disable-scroll": true,
            "sort-by-name": true
        },
        "hyprland/window": {
            "separate-outputs": true
        },
        "layer": "top",
        "position": "top", 
        "modules-left": ["custom/os_button", "hyprland/workspaces", "sway/workspaces"],
        "modules-right": ["custom/music", "pulseaudio", "backlight", "battery", "network", "clock", "tray", "custom/lock", "custom/power"],
        "tray": {
            "icon-size": 21,
            "spacing": 10
        },
        "custom/music": {
            "format": "пАБ  {}",
            "escape": true,
            "interval": 5,
            "tooltip": false,
            "exec": "playerctl metadata --format='{{ title }}'",
            "on-click": "playerctl play-pause",
            "max-length": 50
        },
        "clock": {
            "timezone": "Asia/Dubai",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "о™∞ {:%d/%m/%Y}",
            "format": "оЩБ {:%H:%M}"
        },
        "backlight": {
            "device": "intel_backlight",
            "format": "{icon}",
            "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
        },
        "battery": {
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format": "{icon}",
            "format-charging": "пЦГ",
            "format-plugged": "пЦГ",
            "format-alt": "{icon}",
            "format-icons": ["пЦВ", "пХє",  "пХЇ", "пХї", "пХЉ", "пХљ", "пХљ", "пХЊ", "пХњ", "пЦА", "пЦБ", "пХЄ"]
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "пС¶",
            "format-icons": {
                "default": ["пА¶", "пАІ", "пА® "]
            },
            "on-click": "pavucontrol"
        },
        "network": {
            "format-wifi": " {icon}",
            "format-ethernet": " ођБ ",
            "format-disconnected": "у∞МЩ",
            "format-icons": [
                "у∞§ѓ ",
            "у∞§Я ",
            "у∞§Ґ ",
            "у∞§Ґ ",
            "у∞§® "
            ],
            "on-click": "kitty -e nmtui"

        },
        "custom/lock": {
            "tooltip": false,
            "on-click": "sh -c '(sleep 0.5s; swaylock -c 222426)' & disown",
            "format": "пА£"
        },
        "custom/power": {
            "tooltip": false,
            "on-click": "wlogout &",
            "format": "вПї"
        }
},
{
    "name": "bottom",
    "layer": "bottom",
    "position": "bottom",
    "wlr/taskbar": {
        "format": "{icon} {title:.17}",
        "icon-size": 28,
        "spacing": 3,
        "on-click-middle": "close",
        "tooltip-format": "{title}",
        "ignore-list": [],
