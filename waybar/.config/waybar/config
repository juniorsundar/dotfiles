[{    
    "name": "top",
        "custom/os_button": {
            "format": "ΎΝΥ",
            "on-click": "rofi -show drun",
            "tooltip": false
        },
        "sway/workspaces": {
            "disable-scroll": true,
            "format": "{icon}",
        },
        "hyprland/workspaces": {
            "format": "{icon}",
            "on-scroll-up": "hyprctl dispatch workspace e+1",
            "on-scroll-down": "hyprctl dispatch workspace e-1",
            "disable-scroll": true,
            "sort-by-name": true
        },
        "hyprland/window": {
            "separate-outputs": true
        },
        "layer": "top",
        "position": "top", 
        "modules-left": ["custom/os_button", "hyprland/workspaces", "sway/workspaces"],
        "modules-right": ["custom/music", "pulseaudio", "backlight", "battery", "network", "clock", "tray","custom/notification", "custom/lock", "custom/power"],
        "tray": {
            "icon-size": 21,
            "spacing": 10
        },
        "custom/music": {
            "format": "ΎΑΒ  {}",
            "escape": true,
            "interval": 5,
            "tooltip": false,
            "exec": "playerctl metadata --format='{{ title }}'",
            "on-click": "playerctl play-pause",
            "max-length": 50
        },
        "clock": {
            "timezone": "Asia/Dubai",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "Ός░ {:%d/%m/%Y}",
            "format": "ΌβΒ {:%H:%M}"
        },
        "backlight": {
            "device": "intel_backlight",
            "format": "{icon}",
            "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
        },
        "battery": {
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format": "{icon}",
            "format-charging": "ΎΨΔ",
            "format-plugged": "ΎΨΔ",
            "format-alt": "{icon}",
            "format-icons": ["ΎΨΓ", "ΎΧ╣",  "ΎΧ║", "ΎΧ╗", "ΎΧ╝", "ΎΧ╜", "ΎΧ╜", "ΎΧ╛", "ΎΧ┐", "ΎΨΑ", "ΎΨΒ", "ΎΧ╕"]
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "ΎΣο",
            "format-icons": {
                "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
            },
            "on-click": "pavucontrol"
        },
        "network": {
            "format-wifi": " {icon}",
            "format-ethernet": " ΌυΒ ",
            "format-disconnected": "≤░Νβ",
            "format-icons": [
                "≤░νψ ",
            "≤░νθ ",
            "≤░νλ ",
            "≤░νλ ",
            "≤░νρ "
            ],
            "on-click": "nm-connection-editor"
        },
        "custom/lock": {
            "tooltip": false,
            "on-click": "sh -c '(sleep 0.5s; swaylock -c 222426)' & disown",
            "format": "ΎΑμ"
        },
        "custom/power": {
            "tooltip": false,
            "on-click": "wlogout &",
            "format": "έΠ╗"
        },
        "custom/notification": {
            "tooltip": false,
            "format": "{} {icon}",
            "format-icons": {
                "notification": "≤▒Ζτ",
                "none": "ΎΔ│",
                "dnd-notification": "ΎΘ╢ ",
                "dnd-none": "≤░Γδ",
                "inhibited-notification": "ΎΓλ ",
                "inhibited-none": "ΎΓλ",
                "dnd-inhibited-notification": "ΎΘ╖ ",
                "dnd-inhibited-none": "ΎΘ╖ "
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "sleep 0.1 && swaync-client -t -sw",
            "on-click-right": "sleep 0.1 && swaync-client -d -sw",
            "escape": true
        }
},
{
    "name": "bottom",
    "layer": "bottom",
    "position": "bottom",
    "wlr/taskbar": {
        "format": "{icon} {title:.17}",
        "icon-size": 28,
        "spacing": 3,
        "on-click-middle": "close",
        "tooltip-format": "{title}",
        "ignore-list": [],
        "on-click": "activate"
    },
    "modules-center": []
}]
