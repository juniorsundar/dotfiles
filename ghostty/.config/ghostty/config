font-family = Lilex Nerd Font

font-family-bold = Lilex Nerd Font
font-family-italic = Lilex Nerd Font
font-family-bold-italic = Lilex Nerd Font

gtk-titlebar = true
gtk-toolbar-style = flat
window-decoration = server
font-size = 11

theme = Doom One

keybind = clear
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab
keybind = ctrl+shift+d=close_surface
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+shift+|=new_split:right
keybind = ctrl+shift+_=new_split:down
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+down=goto_split:bottom
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+alt+right=resize_split:right,10
keybind = ctrl+shift+alt+down=resize_split:down,10
keybind = ctrl+shift+alt+left=resize_split:left,10
keybind = ctrl+shift+alt+up=resize_split:up,10
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+,=reload_config
keybind = ctrl+shift+h=write_screen_file:open,vt

window-padding-balance = true
window-padding-x = 5
window-padding-y = 2
